{
  "expo": {
    "name": "NewCoach",
    "slug": "newcoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "newcoach",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1F2A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.newcoach.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B1F2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "co.newcoach.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53ee86e4-9e08-4664-9020-e4edeaaa08af"
      }
    },
    "owner": "betexcr"
  }
}
